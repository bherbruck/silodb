# silodb-server configuration — copy to `.env` (git-ignored) and fill in.
# `docker compose up` reads this automatically; for a bare binary,
# `set -a; . ./.env; set +a` or export the variables yourself.

# --- tokens (unscoped root credentials; a role with no token is disabled).
# --- All optional: with none set, the server generates an admin token and
# --- prints it in the logs on every start. Set SILODB_DDL_TOKEN to make it
# --- stable; day-to-day clients should use keys minted at /admin instead.
SILODB_DDL_TOKEN=change-me
SILODB_READWRITE_TOKEN=
SILODB_READONLY_TOKEN=

# --- policy for tables auto-created by line-protocol writes (/write)
SILODB_DEFAULT_TIERS=1d

# --- background maintenance interval in seconds (compaction, tier merges,
# --- retention, GC); 0 disables — then nothing compacts until you run
# --- silodb_maintain() yourself
SILODB_MAINTAIN_SECS=60

# --- the rest have sensible defaults and are usually left alone
# --- (set in the container by the Dockerfile; override here if composing)
#SILODB_DB=/data/silodb.db          # SQLite file; parquet in <db>.silodb/
#SILODB_ADDR=0.0.0.0:8080           # listen address
#SILODB_COLD_DIR=                   # override the parquet base directory
#SILODB_READERS=4                   # read-only connection pool size
#SILODB_MAX_ROWS=10000              # /sql result cap
